# Backend API used by browser-side dashboard requests.
# For local development, the NestJS API defaults to http://localhost:3001.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional: required only for the Operations Chat feature.
AI_GATEWAY_API_KEY=

# Optional: defaults to openai/gpt-5-nano when unset.
AI_GATEWAY_MODEL=openai/gpt-5-nano
